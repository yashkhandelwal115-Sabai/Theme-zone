{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar color-scheme-{{ section.settings.color_scheme }} text-center py-2" role="region" aria-label="Announcement">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'announcement' -%}
          <div class="announcement-bar__message" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link">
            {%- endif -%}
              <p class="h5 mt-0 mb-0">{{ block.settings.text | escape }}</p>
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
{%- endif -%}

<style>
  .announcement-bar {
    padding: 0.5rem 0;
  }
  .announcement-bar__link {
    text-decoration: underline;
  }
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 1,
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "1", "label": "Electric Blue" },
        { "value": "2", "label": "Arctic White" },
        { "value": "3", "label": "Carbon Black" },
        { "value": "4", "label": "Neon Green" }
      ],
      "default": "1",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
