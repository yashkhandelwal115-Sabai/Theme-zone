{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar-wrapper" style="background-color: var(--color-primary); color: #ffffff; width: 100%; overflow: hidden; position: relative;">
    <div class="page-width">
      <div class="announcement-bar text-center py-2 relative flex justify-center items-center" role="region" aria-label="Announcement">
        
        {%- assign active_announcement = section.blocks.first -%}
        
        <div class="announcement-bar__message w-full text-center" {{ active_announcement.shopify_attributes }}>
          {%- if active_announcement.settings.link != blank -%}
            <a href="{{ active_announcement.settings.link }}" class="announcement-bar__link text-white no-underline hover:underline">
          {%- endif -%}
          
            <p class="text-sm font-medium m-0 px-4 leading-snug">
              {{ active_announcement.settings.text | escape }}
            </p>
            
          {%- if active_announcement.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>
{%- endif -%}

<style>
  .announcement-bar-wrapper {
    z-index: 101;
  }
  .announcement-bar__message {
    max-width: 100%;
    word-break: break-word;
  }
  .text-white { color: #ffffff !important; }
  .no-underline { text-decoration: none; }
  .hover\:underline:hover { text-decoration: underline; }
  .text-sm { font-size: 0.875rem; }
  .font-medium { font-weight: 500; }
  .leading-snug { line-height: 1.375; }
  .py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
</style>

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 1,
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on all orders over $99 • Limited time offer!",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
