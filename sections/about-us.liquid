{{ 'page-about.css' | asset_url | stylesheet_tag }}

<div class="tz-page-about">
  
  <!-- Hero Banner -->
  <div class="tz-page-about__hero">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | img_url: 'master' }}" alt="{{ section.settings.hero_heading }}" class="tz-page-about__hero-img">
    {%- else -%}
      <!-- Premium placeholder gradient -->
      <div class="tz-page-about__hero-overlay"></div>
      <div class="tz-page-about__hero-pattern"></div>
    {%- endif -%}
    
    <div class="tz-page-about__hero-content">
      <h1 class="tz-page-about__hero-title">{{ section.settings.hero_heading }}</h1>
      <p class="tz-page-about__hero-text">{{ section.settings.hero_text }}</p>
    </div>
  </div>

  <!-- Company Story -->
  <div class="tz-page-about__story">
    <div class="tz-page-about__story-content">
      <h2 class="tz-page-about__story-title">{{ section.settings.story_heading }}</h2>
      <div class="tz-page-about__story-text">
        {{ section.settings.story_content }}
      </div>
    </div>
    <div class="tz-page-about__story-visual">
      <div class="tz-page-about__story-decor"></div>
      {%- if section.settings.story_image != blank -%}
        <img src="{{ section.settings.story_image | img_url: '800x' }}" class="tz-page-about__story-image" alt="Our Story">
      {%- else -%}
        <div class="tz-page-about__story-placeholder">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L28 20M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- Mission & Vision -->
  <div class="tz-page-about__mission">
    <div class="tz-page-about__mission-grid">
      <div class="tz-card-mission">
        <div class="tz-card-mission__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="tz-card-mission__title">{{ section.settings.mission_heading }}</h3>
        <p class="tz-card-mission__text">{{ section.settings.mission_text }}</p>
      </div>
      <div class="tz-card-mission">
        <div class="tz-card-mission__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
        </div>
        <h3 class="tz-card-mission__title">{{ section.settings.vision_heading }}</h3>
        <p class="tz-card-mission__text">{{ section.settings.vision_text }}</p>
      </div>
    </div>
  </div>

  <!-- Statistics -->
  <div class="tz-page-about__stats">
    <div class="tz-page-about__stats-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="tz-stat" {{ block.shopify_attributes }}>
            <div class="tz-stat__number">{{ block.settings.number }}</div>
            <div class="tz-stat__label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Team Members -->
  <div class="tz-page-about__team">
    <div class="tz-page-about__team-header">
      <h2 class="tz-page-about__team-title">{{ section.settings.team_heading }}</h2>
      <p class="tz-page-about__team-subtitle">{{ section.settings.team_subheading }}</p>
    </div>
    
    <div class="tz-page-about__team-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'team_member' -%}
          <div class="tz-card-team" {{ block.shopify_attributes }}>
            <div class="tz-card-team__img-wrapper">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | img_url: '500x' }}" class="tz-card-team__img" alt="{{ block.settings.name }}">
              {%- else -%}
                <div class="tz-card-team__placeholder">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
              {%- endif -%}
            </div>
            <h4 class="tz-card-team__name">{{ block.settings.name }}</h4>
            <p class="tz-card-team__role">{{ block.settings.role }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- CTA Banner -->
  <div class="tz-page-about__cta">
    <div class="tz-card-cta">
      <div class="tz-card-cta__pattern"></div>
      <h2 class="tz-card-cta__title">{{ section.settings.cta_heading }}</h2>
      <p class="tz-card-cta__text">{{ section.settings.cta_text }}</p>
      <a href="{{ section.settings.cta_link }}" class="tz-btn--cta">
        {{ section.settings.cta_button_text }}
      </a>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "About Us Page",
  "settings": [
    {
      "type": "header",
      "content": "Hero Banner"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
