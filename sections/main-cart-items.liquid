<div class="cart-items-section page-width py-8">
  <div class="cart__header flex justify-between align-center mb-8">
    <h1 class="h2">{{ 'sections.cart.title' | t }}</h1>
    <a href="{{ routes.all_products_collection_url }}" class="underlined-link">{{ 'general.continue_shopping' | t }}</a>
  </div>

  {%- if cart == empty -%}
    <div class="cart__empty text-center py-8">
      <h2 class="h3">{{ 'sections.cart.empty' | t }}</h2>
      <a href="{{ routes.all_products_collection_url }}" class="button button--primary mt-4">{{ 'general.continue_shopping' | t }}</a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <table class="cart-items w-100">
        <thead>
          <tr>
            <th class="text-left" colspan="2" scope="col">Product</th>
            <th class="text-center" scope="col">Quantity</th>
            <th class="text-right" scope="col">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">
              <td class="cart-item__media">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 300 }}" class="cart-item__image rounded" alt="{{ item.image.alt | escape }}" loading="lazy" width="150" height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}">
                {% endif %}
              </td>
              <td class="cart-item__details">
                {%- if section.settings.show_vendor -%}
                  <p class="caption-with-letter-spacing light">{{ item.product.vendor }}</p>
                {%- endif -%}

                <a href="{{ item.url }}" class="cart-item__name h4 break">{{ item.product.title | escape }}</a>

                {%- if item.original_price != item.final_price -%}
                  <div class="cart-item__discounted-prices">
                    <span class="visually-hidden">Regular price</span>
                    <s class="cart-item__old-price price price--end">{{ item.original_price | money }}</s>
                    <span class="visually-hidden">Sale price</span>
                    <span class="price price--end">{{ item.final_price | money }}</span>
                  </div>
                {%- else -%}
                  <div class="product-option">{{ item.original_price | money }}</div>
                {%- endif -%}

                {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != nil -%}
                  <dl>
                    {%- if item.product.has_only_default_variant == false -%}
                      {%- for option in item.options_with_values -%}
                        <div class="product-option">
                          <dt>{{ option.name }}: </dt>
                          <dd>{{ option.value }}</dd>
                        </div>
                      {%- endfor -%}
                    {%- endif -%}

                    {%- for property in item.properties -%}
                      {%- assign property_first_char = property.first | slice: 0 -%}
                      {%- if property.last != blank and property_first_char != '_' -%}
                        <div class="product-option">
                          <dt>{{ property.first }}: </dt>
                          <dd>
                            {%- if property.last contains '/uploads/' -%}
                              <a href="{{ property.last }}" class="link" target="_blank">File</a>
                            {%- else -%}
                              {{ property.last }}
                            {%- endif -%}
                          </dd>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </dl>

                  <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                {%- endif -%}

                <ul class="discounts list-unstyled" role="list" aria-label="Discounts">
                  {%- for discount in item.discounts -%}
                    <li class="discounts__discount">
                      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-discount color-foreground-text" viewBox="0 0 12 12" width="12" height="12"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 0h3a2 2 0 012 2v3a1 1 0 01-.3.7l-6 6a1 1 0 01-1.4 0l-4-4a1 1 0 010-1.4l6-6A1 1 0 017 0zm2 2a1 1 0 102 0 1 1 0 00-2 0z" fill="currentColor"/></svg>
                      {{ discount.title }}
                    </li>
                  {%- endfor -%}
                </ul>

                {%- if item.variant.unit_price_measurement -%}
                  <div class="unit-price caption">
                    <span class="visually-hidden">Unit price</span>
                    {{ item.variant.unit_price | money }}
                    <span aria-hidden="true">/</span>
                    <span class="visually-hidden">&nbsp;per&nbsp;</span>
                    {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                      {{- item.variant.unit_price_measurement.reference_value -}}
                    {%- endif -%}
                    {{ item.variant.unit_price_measurement.reference_unit }}
                  </div>
                {%- endif -%}
              </td>

              <td class="cart-item__quantity text-center">
                <div class="cart-item__quantity-wrapper">
                  <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">Quantity</label>
                  <div class="quantity js-quantity-selector">
                    <button class="quantity__button no-js-hidden js-qty-minus" name="minus" type="button">-</button>
                    <input class="quantity__input" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.product.title | escape }}" id="Quantity-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                    <button class="quantity__button no-js-hidden js-qty-plus" name="plus" type="button">+</button>
                  </div>
                  <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                    <a href="{{ item.url_to_remove }}" class="button button--tertiary mt-2" aria-label="Remove {{ item.product.title | escape }}">Remove</a>
                  </cart-remove-button>
                </div>
              </td>

              <td class="cart-item__totals text-right">
                <div class="cart-item__price-wrapper">
                  {%- if item.original_line_price != item.final_line_price -%}
                    <dl class="cart-item__discounted-prices">
                      <dt class="visually-hidden">Regular price</dt>
                      <dd><s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s></dd>
                      <dt class="visually-hidden">Sale price</dt>
                      <dd><span class="price price--end">{{ item.final_line_price | money }}</span></dd>
                    </dl>
                  {%- else -%}
                    <span class="price price--end">{{ item.original_line_price | money }}</span>
                  {%- endif -%}
                </div>
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
      <div class="cart__footer-wrapper mt-4 text-right">
         <button type="submit" class="button button--secondary no-js" name="update" form="cart">Update Cart</button>
      </div>
    </form>
  {%- endif -%}
</div>

<style>
  .flex { display: flex; }
  .justify-between { justify-content: space-between; }
  .align-center { align-items: center; }
  .cart-items th { border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 1rem; font-weight: bold; }
  .cart-item td { padding: 2rem 0; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .cart-item__media { width: 150px; }
  .cart-item__details { padding-left: 2rem; }
  .cart-item__name { text-decoration: none; font-weight: bold; }
  .cart-item__name:hover { text-decoration: underline; }
  .product-option { font-size: 0.9rem; color: rgba(0,0,0,0.7); display: flex; gap: 0.5rem; }
  .product-option dt { font-weight: bold; }
  .cart-item__quantity-wrapper { display: flex; flex-direction: column; align-items: center; }
  .discounts { margin-top: 0.5rem; color: #E32C2B; font-size: 0.9rem; }
  .icon-discount { vertical-align: middle; margin-right: 0.25rem; }
  .unit-price { color: rgba(0,0,0,0.6); margin-top: 0.5rem; }
  @media screen and (max-width: 749px) {
    .cart-items thead { display: none; }
    .cart-item { display: grid; grid-template-columns: 1fr 2fr; gap: 1rem; }
    .cart-item td { padding: 1rem 0; border: none; }
    .cart-item__media { grid-row: 1 / 3; }
    .cart-item__details { grid-column: 2; padding-left: 0; }
    .cart-item__quantity { grid-column: 2; text-align: left; }
    .cart-item__quantity-wrapper { align-items: flex-start; }
    .cart-item__totals { display: none; }
  }
</style>

<script>
  document.querySelectorAll('.js-quantity-selector button').forEach(button => {
    button.addEventListener('click', function() {
      const input = this.parentElement.querySelector('input');
      let val = parseInt(input.value);
      if (this.name === 'plus') {
        input.value = val + 1;
      } else if (this.name === 'minus' && val > 0) {
        input.value = val - 1;
      }
      document.querySelector('#cart').submit();
    });
  });
</script>

{% schema %}
{
  "name": "Cart items",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    }
  ]
}
{% endschema %}
