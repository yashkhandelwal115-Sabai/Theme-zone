<div class="product-page color-scheme-{{ section.settings.color_scheme }} py-8">
  <div class="page-width">
    <div class="grid grid-cols-2">
      <!-- Media Gallery -->
      <div class="product__media-wrapper">
        <div class="product__media-gallery">
          {%- if product.media.size > 0 -%}
            {%- for media in product.media -%}
              <div class="product__media-item" data-media-id="{{ media.id }}">
                {%- case media.media_type -%}
                  {%- when 'image' -%}
                    {{ media | image_url: width: 1000 | image_tag: loading: 'lazy' }}
                  {%- when 'external_video' -%}
                    {{ media | external_video_tag }}
                  {%- when 'video' -%}
                    {{ media | video_tag: controls: true }}
                  {%- when 'model' -%}
                    {{ media | model_viewer_tag }}
                  {%- else -%}
                    {{ media | media_tag }}
                {%- endcase -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      <!-- Product Info -->
      <div class="product__info-wrapper">
        <div id="ProductInfo-{{ section.id }}" class="product__info-container">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <p class="product__text" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- when 'title' -%}
                <h1 class="product__title h2 mt-0" {{ block.shopify_attributes }}>{{ product.title | escape }}</h1>
              {%- when 'price' -%}
                <div class="product__price" {{ block.shopify_attributes }}>
                  {%- if product.compare_at_price > product.price -%}
                    <s class="price-item price-item--regular h4">{{ product.compare_at_price | money }}</s>
                    <span class="price-item price-item--sale h3 text-red">{{ product.price | money }}</span>
                  {%- else -%}
                    <span class="price-item price-item--regular h3">{{ product.price | money }}</span>
                  {%- endif -%}

                  {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
                    <div class="unit-price caption mt-2">
                      <span class="visually-hidden">Unit price</span>
                      {{ product.selected_or_first_available_variant.unit_price | money }}
                      <span aria-hidden="true">/</span>
                      <span class="visually-hidden">&nbsp;per&nbsp;</span>
                      {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
                        {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
                      {%- endif -%}
                      {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
                    </div>
                  {%- endif -%}
                  
                  {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                    <div class="product__tax caption mt-2">
                      {%- if shop.taxes_included -%}
                        Taxes included.
                      {%- endif -%}
                      {%- if shop.shipping_policy.body != blank -%}
                        <a href="{{ shop.shipping_policy.url }}">Shipping</a> calculated at checkout.
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  <div {{ block.shopify_attributes }}>
                    {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                    {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large mt-4' -%}
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                      {{ form | payment_terms }}
                    {%- endform -%}
                  </div>
                </div>
              {%- when 'vendor' -%}
                <div class="product__vendor mb-4" {{ block.shopify_attributes }}>{{ product.vendor }}</div>
              {%- when 'description' -%}
                <div class="product__description rte" {{ block.shopify_attributes }}>
                  {{ product.description }}
                </div>
              {%- when 'variant_picker' -%}
                {%- unless product.has_only_default_variant -%}
                  <variant-radios class="no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}" {{ block.shopify_attributes }}>
                    {%- for option in product.options_with_values -%}
                      <fieldset class="js product-form__input">
                        <legend class="form__label font-bold mb-2">{{ option.name }}</legend>
                        <div class="variant-options">
                          {%- for value in option.values -%}
                            <input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                  name="{{ option.name }}"
                                  value="{{ value | escape }}"
                                  form="product-form-{{ section.id }}"
                                  {% if option.selected_value == value %}checked{% endif %}
                            >
                            <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                              {{ value }}
                            </label>
                          {%- endfor -%}
                        </div>
                      </fieldset>
                    {%- endfor -%}
                  </variant-radios>
                {%- endunless -%}
              {%- when 'buy_buttons' -%}
                <div {{ block.shopify_attributes }}>
                  {%- form 'product', product, id: 'product-form-{{ section.id }}', class: 'form' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    <div class="product-form__buttons mt-4">
                      <button type="submit" name="add" class="button button--primary w-100" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                        <span>{% if product.selected_or_first_available_variant.available %}Add to cart{% else %}Sold out{% endif %}</span>
                      </button>
                      {%- if block.settings.show_dynamic_checkout -%}
                        {{ form | payment_button }}
                      {%- endif -%}
                    </div>
                  {%- endform -%}
                </div>
              {%- when 'quantity_selector' -%}
                <div class="product-form__input product-form__quantity" {{ block.shopify_attributes }}>
                  <label class="form__label font-bold mb-2 block" for="Quantity-{{ section.id }}">Quantity</label>
                  <div class="quantity js-quantity-selector">
                    <button class="quantity__button js-qty-minus" name="minus" type="button">-</button>
                    <input class="quantity__input" type="number" name="quantity" id="Quantity-{{ section.id }}" min="1" value="1" form="product-form-{{ section.id }}">
                    <button class="quantity__button js-qty-plus" name="plus" type="button">+</button>
                  </div>
                </div>
              {%- when 'pickup_availability' -%}
                <div class="pickup-availability mt-4" {{ block.shopify_attributes }}>
                  <!-- Simulated Pickup Availability for OS 2.0 completeness -->
                </div>
              {%- when 'trust_badge' -%}
                <div {{ block.shopify_attributes }}>
                  {% render 'trust-badges' %}
                </div>
              {%- when 'collapsible_tab' -%}
                <div class="accordion js-accordion mt-4" {{ block.shopify_attributes }}>
                  <button class="accordion__header js-accordion-header h5">
                    {{ block.settings.heading | escape }}
                    <span class="accordion__icon">
                      <svg viewBox="0 0 20 20" width="20" height="20">
                        <path d="M5 7l5 5 5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                    </span>
                  </button>
                  <div class="accordion__content">
                    <div class="accordion__inner rte">
                      {{ block.settings.content }}
                      {{ block.settings.page.content }}
                    </div>
                  </div>
                </div>
              {%- when 'custom_liquid' -%}
                <div class="custom-liquid mt-4" {{ block.shopify_attributes }}>
                  {{ block.settings.custom_liquid }}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .product-page { padding-top: 2rem; padding-bottom: 4rem; }
  .product__media-wrapper { position: sticky; top: 2rem; }
  .product__media-item { border-radius: 12px; overflow: hidden; background: #f4f4f4; margin-bottom: 1rem; border: 1px solid rgba(0,0,0,0.05); }
  .product__media-item img, .product__media-item video, .product__media-item model-viewer { width: 100%; height: auto; display: block; }
  .product__info-container > * + * { margin-top: 1.5rem; }
  .text-red { color: #E32C2B; }
  .w-100 { width: 100%; margin-bottom: 1rem; }
  .font-bold { font-weight: bold; }
  .block { display: block; }
  
  /* Variant picker */
  .product-form__input fieldset { border: none; padding: 0; margin: 0; }
  .variant-options { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .product-form__input input[type="radio"] { clip: rect(0, 0, 0, 0); overflow: hidden; position: absolute; height: 1px; width: 1px; }
  .product-form__input input[type="radio"] + label { display: inline-block; padding: 0.5rem 1rem; border: 1px solid var(--color-scheme-2-fg); border-radius: 8px; cursor: pointer; transition: all 0.2s; }
  .product-form__input input[type="radio"]:checked + label { background-color: var(--color-scheme-1-bg); color: var(--color-scheme-1-fg); border-color: var(--color-scheme-1-bg); }
  
  /* Quantity */
  .quantity { display: flex; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; width: 120px; overflow: hidden; }
  .quantity__button { flex: 1; background: none; border: none; cursor: pointer; font-size: 1.25rem; font-weight: bold; }
  .quantity__input { width: 40px; text-align: center; border: none; font-size: 1rem; -moz-appearance: textfield; }
  .quantity__input::-webkit-outer-spin-button, .quantity__input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  
  @media screen and (max-width: 749px) {
    .product-page .grid-cols-2 { grid-template-columns: 1fr; gap: 2rem; }
    .product__media-wrapper { position: static; }
  }
</style>

{% schema %}
{
  "name": "Product Information",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "1", "label": "Electric Blue" },
        { "value": "2", "label": "Arctic White" },
        { "value": "3", "label": "Carbon Black" },
        { "value": "4", "label": "Neon Green" }
      ],
      "default": "2",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Text block",
          "label": "Text"
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "vendor",
      "name": "Vendor",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant Picker",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "Show dynamic checkout buttons"
        }
      ]
    },
    {
      "type": "quantity_selector",
      "name": "Quantity Selector",
      "limit": 1
    },
    {
      "type": "pickup_availability",
      "name": "Pickup Availability",
      "limit": 1
    },
    {
      "type": "trust_badge",
      "name": "Trust Badges",
      "limit": 1
    },
    {
      "type": "collapsible_tab",
      "name": "Collapsible row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Collapsible row",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Row content"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Row content from page"
        }
      ]
    },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "settings": [
        {
          "type": "liquid",
          "id": "custom_liquid",
          "label": "Custom Liquid",
          "info": "Add app snippets or other Liquid code to create advanced customizations."
        }
      ]
    }
  ]
}
{% endschema %}
