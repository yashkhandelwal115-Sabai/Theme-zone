<footer class="theme-footer" id="footer-v2">
  <div class="footer-container">
    
    <!-- Newsletter Section -->
    <div class="footer-newsletter">
      <div class="newsletter-left">
        <div class="newsletter-icon">
          <!-- Paper plane SVG -->
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M22 2L15 22L11 13L2 9L22 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="newsletter-text">
          <h2>Stay Updated!</h2>
          <p>Subscribe to get updates on new arrivals, exclusive deals, and product launches.</p>
        </div>
      </div>
      
      <div class="newsletter-right">
        {% form 'customer', class: 'newsletter-form' %}
          <div class="newsletter-input-group">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="Enter your email address" required>
            <button type="submit">Subscribe</button>
          </div>
        {% endform %}
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div class="footer-main-grid">
      
      <!-- Column 1: Brand -->
      <div class="footer-column brand-column">
        <a href="{{ routes.root_url }}" class="footer-logo">
          Theme<span>Zone</span>
        </a>
        <p class="brand-desc">
          Premium electronics store offering the latest tech, gadgets, and accessories with unbeatable quality and pricing.
        </p>
        <div class="social-icons">
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg></a>
          {%- else -%}
            <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg></a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" aria-label="Twitter"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"></path></svg></a>
          {%- else -%}
            <a href="#" aria-label="Twitter"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.008 4.076H5.078z"></path></svg></a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
          {%- else -%}
            <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33 2.78 2.78 0 001.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.33 29 29 0 00-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg></a>
          {%- else -%}
            <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33 2.78 2.78 0 001.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.33 29 29 0 00-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg></a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1.04-.1z"></path></svg></a>
          {%- else -%}
            <a href="#" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1.04-.1z"></path></svg></a>
          {%- endif -%}
        </div>
      </div>

      <!-- Dynamic Menu Blocks -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          {%- assign default_heading = "Menu" -%}
          {%- if forloop.index == 1 -%}{%- assign default_heading = "Shop" -%}{%- endif -%}
          {%- if forloop.index == 2 -%}{%- assign default_heading = "Customer Service" -%}{%- endif -%}
          {%- if forloop.index == 3 -%}{%- assign default_heading = "Company" -%}{%- endif -%}
          
          <div class="footer-column footer-accordion" {{ block.shopify_attributes }}>
            <h3 class="footer-heading">
              {{ block.settings.heading | default: block.settings.menu.title | default: default_heading }}
              <svg class="accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </h3>
            <ul class="footer-links">
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                <!-- Premium Fallback based on block index -->
                {%- if forloop.index == 1 -%}
                  <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
                  <li><a href="{{ routes.all_products_collection_url }}">Smartphones</a></li>
                  <li><a href="{{ routes.all_products_collection_url }}">Laptops</a></li>
                  <li><a href="{{ routes.all_products_collection_url }}">Gaming</a></li>
                  <li><a href="{{ routes.all_products_collection_url }}">Audio</a></li>
                  <li><a href="{{ routes.all_products_collection_url }}">Accessories</a></li>
                  <li><a href="{{ routes.all_products_collection_url }}">Smart Home</a></li>
                {%- elsif forloop.index == 2 -%}
                  <li><a href="/pages/contact">Contact Us</a></li>
                {%- else -%}
                  <li><a href="#">Link 1</a></li>
                  <li><a href="#">Link 2</a></li>
                  <li><a href="#">Link 3</a></li>
                {%- endif -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Column 5: Legal -->
      <div class="footer-column footer-accordion">
        <h3 class="footer-heading">
          Legal
          <svg class="accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </h3>
        <ul class="footer-links">
          {%- if shop.privacy_policy != blank -%}
            <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
          {%- endif -%}
          {%- if shop.terms_of_service != blank -%}
            <li><a href="{{ shop.terms_of_service.url }}">Terms & Conditions</a></li>
          {%- endif -%}
          {%- if shop.refund_policy != blank -%}
            <li><a href="{{ shop.refund_policy.url }}">Refund Policy</a></li>
          {%- endif -%}
          {%- if shop.shipping_policy != blank -%}
            <li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Column 6: We Accept -->
      <div class="footer-column footer-accordion">
        <h3 class="footer-heading">
          We Accept
          <svg class="accordion-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </h3>
        <div class="footer-links payment-methods">
          {%- for type in shop.enabled_payment_types -%}
            <div class="payment-icon">
              {{ type | payment_type_svg_tag }}
            </div>
          {%- else -%}
            <!-- Fallback if no payment providers configured -->
            {%- assign premium_payments = "visa,master,american_express,paypal" | split: "," -%}
            {%- for type in premium_payments -%}
              <div class="payment-icon">
                {{ type | payment_type_svg_tag }}
              </div>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="copyright">
        &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.
      </div>

      <div class="footer-legal-links">
        {%- if shop.privacy_policy != blank -%}
          <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
        {%- endif -%}
        {%- if shop.terms_of_service != blank -%}
          <a href="{{ shop.terms_of_service.url }}">Terms & Conditions</a>
        {%- endif -%}
      </div>

      <button id="back-to-top" class="back-to-top" aria-label="Back to top">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
      </button>
    </div>

  </div>
</footer>

<style>
  .theme-footer {
    background: linear-gradient(180deg, #020817 0%, #071B46 100%);
    color: #fff;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    padding: 60px 0 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* Newsletter */
  .footer-newsletter {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 60px;
    backdrop-filter: blur(10px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    position: relative;
    overflow: hidden;
  }

  .footer-newsletter::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: rgba(37, 99, 235, 0.15);
    filter: blur(80px);
    border-radius: 50%;
    pointer-events: none;
  }

  .newsletter-left {
    display: flex;
    align-items: center;
    gap: 24px;
    z-index: 1;
  }

  .newsletter-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #3B82F6, #2563EB);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    box-shadow: 0 10px 25px rgba(37, 99, 235, 0.4), inset 0 2px 5px rgba(255,255,255,0.3);
    position: relative;
    overflow: hidden;
  }
  
  .newsletter-icon::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, transparent 60%);
    opacity: 0.5;
    animation: pulseGlow 3s infinite alternate;
  }
  
  @keyframes pulseGlow {
    0% { transform: scale(0.8); opacity: 0.3; }
    100% { transform: scale(1.2); opacity: 0.7; }
  }

  .newsletter-icon svg {
    width: 40px;
    height: 40px;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
    position: relative;
    z-index: 2;
  }

  .newsletter-text h2 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 8px;
    color: #fff;
  }

  .newsletter-text p {
    font-size: 15px;
    color: #9CA3AF;
    margin: 0;
    max-width: 400px;
    line-height: 1.5;
  }

  .newsletter-right {
    flex: 1;
    max-width: 500px;
    z-index: 1;
  }

  .newsletter-input-group {
    display: flex;
    gap: 12px;
  }

  .newsletter-input-group input {
    flex: 1;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 16px 20px;
    color: #fff;
    font-size: 15px;
    outline: none;
    transition: all 0.3s ease;
  }

  .newsletter-input-group input:focus {
    border-color: #3B82F6;
    box-shadow: 0 0 0 1px #3B82F6;
  }

  .newsletter-input-group button {
    background: linear-gradient(90deg, #2563EB, #3B82F6);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0 32px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .newsletter-input-group button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3);
  }

  /* Main Grid */
  .footer-main-grid {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 1fr 1.5fr;
    gap: 40px;
    margin-bottom: 60px;
  }

  .brand-column {
    padding-right: 40px;
  }

  .footer-logo {
    display: inline-block;
    font-size: 28px;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    margin-bottom: 20px;
  }

  .footer-logo span {
    color: #3B82F6;
  }

  .brand-desc {
    color: #9CA3AF;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .social-icons {
    display: flex;
    gap: 12px;
  }

  .social-icons a {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9CA3AF;
    transition: all 0.3s ease;
  }

  .social-icons a svg {
    width: 16px;
    height: 16px;
  }

  .social-icons a:hover {
    background: #2563EB;
    border-color: #2563EB;
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(37, 99, 235, 0.4);
  }

  .footer-heading {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .accordion-icon {
    width: 20px;
    height: 20px;
    display: none;
    transition: transform 0.3s ease;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .footer-links a:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(59, 130, 246, 0.5);
  }

  .payment-methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .payment-icon {
    background: #fff;
    border-radius: 6px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }

  .payment-icon svg {
    max-height: 100%;
    width: auto;
  }

  /* Bottom Bar */
  .footer-bottom {
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .copyright {
    color: #9CA3AF;
    font-size: 14px;
  }

  .footer-legal-links {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .footer-legal-links a {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s ease;
    position: relative;
  }

  .footer-legal-links a:not(:last-child)::after {
    content: '|';
    position: absolute;
    right: -14px;
    color: rgba(255, 255, 255, 0.2);
  }

  .footer-legal-links a:hover {
    color: #fff;
  }

  .back-to-top {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .back-to-top svg {
    width: 20px;
    height: 20px;
  }

  .back-to-top:hover {
    background: #2563EB;
    border-color: #2563EB;
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(37, 99, 235, 0.4);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-main-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .brand-column {
      grid-column: span 2;
      padding-right: 0;
    }
    .footer-newsletter {
      flex-direction: column;
      gap: 30px;
      text-align: center;
    }
    .newsletter-left {
      flex-direction: column;
    }
    .newsletter-right {
      max-width: 100%;
      width: 100%;
    }
    .newsletter-input-group {
      flex-direction: column;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
    .footer-legal-links {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .footer-main-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .brand-column {
      grid-column: span 1;
      margin-bottom: 40px;
    }
    
    /* Mobile Accordion */
    .footer-accordion {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .footer-heading {
      margin: 0;
      padding: 20px 0;
      cursor: pointer;
    }
    .accordion-icon {
      display: block;
    }
    .footer-links {
      height: 0;
      overflow: hidden;
      opacity: 0;
      padding-bottom: 0;
      transition: all 0.3s ease;
    }
    .footer-accordion.is-open .footer-links {
      height: auto;
      opacity: 1;
      padding-bottom: 20px;
    }
    .footer-accordion.is-open .accordion-icon {
      transform: rotate(180deg);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const accordions = document.querySelectorAll('.footer-accordion');
    accordions.forEach(acc => {
      const heading = acc.querySelector('.footer-heading');
      heading.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          const isOpen = acc.classList.contains('is-open');
          if (isOpen) {
            acc.classList.remove('is-open');
          } else {
            acc.classList.add('is-open');
          }
        }
      });
    });

    const backToTop = document.getElementById('back-to-top');
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "Leave blank to use menu title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list"
      },
      {
        "type": "link_list"
      }
    ]
  }
}
{% endschema %}
