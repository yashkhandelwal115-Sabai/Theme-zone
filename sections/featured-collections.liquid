<div class="featured-collections py-12 animate-fade-up">
  <div class="page-width">
    
    <div class="flex justify-between items-center mb-8">
      {%- if section.settings.heading != blank -%}
        <h2 class="h3 m-0 font-bold" style="font-family: var(--font-heading-family);">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.show_view_all and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="button button--secondary text-sm px-6 py-2">View All Collections</a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size == 0 -%}
      <div class="text-center py-12 bg-surface rounded-2xl empty-state" style="border: 2px dashed var(--color-border);">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-secondary); margin-bottom: 1rem;"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        <h3 class="h4 mt-0 mb-2">No collections selected</h3>
        <p class="text-secondary m-0 text-sm">Select collections from Theme Editor to display featured collections here.</p>
      </div>
    {%- else -%}
      <div class="featured-collections__grid">
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          <a href="{{ collection.url | default: '#' }}" class="featured-collection-card group" {{ block.shopify_attributes }}>
            
            <div class="featured-collection-card__image-wrapper">
              {%- if collection.featured_image != blank -%}
                <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" class="featured-collection-card__image" loading="lazy">
              {%- else -%}
                <div class="featured-collection-card__fallback">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
              {%- endif -%}
            </div>
            
            <div class="featured-collection-card__content">
              <div>
                <h3 class="featured-collection-card__title m-0">
                  {{ collection.title | default: 'Collection Title' }}
                </h3>
                <span class="featured-collection-card__count block">
                  {%- if collection != blank -%}
                    {{ collection.all_products_count }} Products
                  {%- else -%}
                    0 Products
                  {%- endif -%}
                </span>
              </div>
              
              <div class="featured-collection-card__arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .featured-collections__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-6);
  }

  .featured-collection-card {
    position: relative;
    background-color: #F8F9FA; /* Light gray mockup background */
    border-radius: 20px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    border: 1px solid transparent;
  }

  .featured-collection-card:hover {
    background-color: #FFFFFF;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
    border-color: var(--color-border);
  }

  .featured-collection-card__image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 80%; /* 5:4 aspect ratio */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .featured-collection-card__image {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .featured-collection-card:hover .featured-collection-card__image {
    transform: translate(-50%, -50%) scale(1.08);
  }

  .featured-collection-card__fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    opacity: 0.2;
  }

  .featured-collection-card__content {
    padding: var(--spacing-5) var(--spacing-6);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: auto;
  }

  .featured-collection-card__title {
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: var(--text-base);
    line-height: 1.2;
    transition: color 0.3s ease;
  }

  .featured-collection-card__count {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-top: var(--spacing-1);
    font-weight: 500;
  }

  .featured-collection-card__arrow {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
  }

  .featured-collection-card:hover .featured-collection-card__arrow {
    background-color: var(--color-primary);
    color: #FFFFFF;
    box-shadow: 0 4px 12px rgba(10, 132, 255, 0.3);
    transform: translateX(4px);
  }

  @media screen and (max-width: 1024px) {
    .featured-collections__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .featured-collections__grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-4);
    }
    .featured-collection-card__content {
      padding: var(--spacing-4);
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Featured Collections",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View All' button"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All link",
      "default": "/collections"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
