{{ 'page-faq.css' | asset_url | stylesheet_tag }}

<div class="tz-page-faq">
  <div class="tz-page-faq__container">
    
    <!-- Header & Search -->
    <div class="tz-page-faq__header">
      <h1 class="tz-page-faq__title">{{ section.settings.heading }}</h1>
      <p class="tz-page-faq__subtitle">{{ section.settings.subheading }}</p>
      
      <div class="tz-page-faq__search-wrapper">
        <input type="text" id="faq-search" placeholder="Search for answers..." class="tz-page-faq__search-input">
        <svg class="tz-page-faq__search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
    </div>

    <!-- Category Filters -->
    <div class="tz-page-faq__filters" id="faq-categories">
      <button class="tz-btn--filter active" data-category="all">All</button>
      <button class="tz-btn--filter" data-category="orders">Orders & Shipping</button>
      <button class="tz-btn--filter" data-category="returns">Returns</button>
      <button class="tz-btn--filter" data-category="warranty">Warranty</button>
      <button class="tz-btn--filter" data-category="tech">Tech Support</button>
    </div>

    <!-- FAQ Accordion List -->
    <div class="tz-page-faq__list" id="faq-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <div class="tz-card-faq faq-item" data-category="{{ block.settings.category | downcase }}" {{ block.shopify_attributes }}>
            <button class="tz-card-faq__question faq-question">
              <span class="tz-card-faq__question-text">{{ block.settings.question }}</span>
              <span class="tz-card-faq__icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </span>
            </button>
            <div class="tz-card-faq__answer faq-answer">
              <div class="tz-card-faq__answer-content">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Empty State -->
    <div id="faq-empty-state" class="tz-page-faq__empty">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <h3>No results found</h3>
      <p>We couldn't find any FAQs matching your search.</p>
    </div>

    <!-- Support CTA -->
    <div class="tz-card-support-large">
      <h2>Still have questions?</h2>
      <p>Can't find the answer you're looking for? Please chat to our friendly team.</p>
      <a href="/pages/contact-us" class="tz-btn--support-large">
        Contact Support
      </a>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Accordion Logic
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-question');
      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        // Close all others
        faqItems.forEach(i => i.classList.remove('is-open'));
        // Toggle current
        if (!isOpen) item.classList.add('is-open');
      });
    });

    // Category Filter Logic
    const filterBtns = document.querySelectorAll('.tz-btn--filter');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active class
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const category = btn.dataset.category;
        let visibleCount = 0;

        faqItems.forEach(item => {
          if (category === 'all' || item.dataset.category.includes(category)) {
            item.style.display = 'block';
            visibleCount++;
          } else {
            item.style.display = 'none';
            item.classList.remove('is-open'); // Close it if hidden
          }
        });

        // Search logic resets if filter changes
        document.getElementById('faq-search').value = '';
        checkEmptyState(visibleCount);
      });
    });

    // Search Logic
    const searchInput = document.getElementById('faq-search');
    searchInput.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      // Reset filters to "All" when searching
      filterBtns.forEach(b => b.classList.remove('active'));
      filterBtns[0].classList.add('active'); // "All" button

      let visibleCount = 0;
      faqItems.forEach(item => {
        const text = item.querySelector('.tz-card-faq__question-text').textContent.toLowerCase();
        if (text.includes(term)) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
          item.classList.remove('is-open');
        }
      });
      checkEmptyState(visibleCount);
    });

    function checkEmptyState(count) {
      const emptyState = document.getElementById('faq-empty-state');
      if (count === 0) {
        emptyState.classList.add('is-visible');
      } else {
        emptyState.classList.remove('is-visible');
      }
    }
  });
</script>

{% schema %}
{
  "name": "FAQ Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know about the product and billing."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            { "value": "orders", "label": "Orders & Shipping" },
            { "value": "returns", "label": "Returns" },
            { "value": "warranty", "label": "Warranty" },
            { "value": "tech", "label": "Tech Support" }
          ],
          "default": "orders"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I track my order?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>You can track your order using the tracking link provided in your shipping confirmation email.</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "faq_item",
        "settings": {
          "category": "orders",
          "question": "What shipping methods do you offer?",
          "answer": "<p>We offer standard, expedited, and next-day shipping options via major carriers. Delivery times depend on your location.</p>"
        }
      },
      {
        "type": "faq_item",
        "settings": {
          "category": "returns",
          "question": "What is your return policy?",
          "answer": "<p>We offer a 30-day money-back guarantee on all unused products in their original packaging. Please contact support to initiate a return.</p>"
        }
      },
      {
        "type": "faq_item",
        "settings": {
          "category": "warranty",
          "question": "Do your products come with a warranty?",
          "answer": "<p>Yes, all electronics come with a standard 1-year manufacturer warranty covering defects in materials and workmanship.</p>"
        }
      },
      {
        "type": "faq_item",
        "settings": {
          "category": "tech",
          "question": "How do I factory reset my device?",
          "answer": "<p>Navigate to Settings > System > Reset Options, and select 'Erase all data'. Please ensure you have backed up your data first.</p>"
        }
      }
    ]
  }
}
{% endschema %}
