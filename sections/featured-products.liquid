<div class="featured-products py-12 animate-fade-up">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="flex justify-between items-end mb-8">
        <h2 class="h2 m-0" style="font-family: var(--font-heading-family);">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.collection != blank and section.settings.show_view_all -%}
          <a href="{{ section.settings.collection.url }}" class="button button--secondary">View All</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign collection = section.settings.collection -%}
    {%- if collection == blank or collection.products_count == 0 -%}
      <div class="text-center py-12 bg-surface rounded-card empty-state" style="border: 2px dashed var(--color-border);">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-secondary); margin-bottom: 1rem;"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        <h3 class="h4 mt-0 mb-2">No products found</h3>
        <p class="text-secondary m-0">Select a collection with products from the Theme Editor.</p>
      </div>
    {%- else -%}
      <div class="featured-products__grid">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <a href="{{ product.url }}" class="product-card card">
            <div class="product-card__media">
              {%- if product.featured_media != blank -%}
                <img src="{{ product.featured_media | image_url: width: 500 }}" alt="{{ product.featured_media.alt | escape }}" loading="lazy" class="product-card__image">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
              {%- endif -%}
            </div>
            <div class="product-card__content text-center">
              <h3 class="product-card__title h6 m-0">{{ product.title | escape }}</h3>
              <div class="product-card__price mt-2 font-bold text-primary">
                {%- if product.compare_at_price > product.price -%}
                  <s class="text-secondary text-sm mr-2">{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                {{ product.price | money }}
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: var(--spacing-6);
  }

  .product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background-color: #FFFFFF;
    border-radius: 16px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    height: 100%;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
    border-color: rgba(0, 0, 0, 0.1);
  }

  .product-card__media {
    position: relative;
    width: 100%;
    padding-top: 100%; /* 1:1 Aspect ratio */
    background-color: var(--color-background);
    overflow: hidden;
  }

  .product-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: var(--spacing-4);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }

  .product-card__content {
    padding: var(--spacing-4);
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-grow: 1;
    background-color: #FFFFFF;
  }

  .product-card__title {
    color: var(--color-text-primary);
    line-height: 1.3;
    font-weight: 600;
  }

  .mr-2 { margin-right: var(--spacing-2); }
  .text-primary { color: var(--color-primary); }

  @media screen and (max-width: 1024px) {
    .featured-products__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .featured-products__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: var(--spacing-4);
    }
    
    .product-card__content {
      padding: var(--spacing-3);
    }
    
    .product-card__title {
      font-size: var(--text-sm);
    }
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Featured Products",
      "label": "Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View all' button"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
