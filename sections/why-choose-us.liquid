<div class="mockup-why-choose-us py-16 animate-fade-up">
  <div class="page-width">
    
    <h2 class="h2 text-center mb-12 font-bold" style="font-size: 1.75rem;">{{ section.settings.heading | escape }}</h2>

    <div class="grid grid-cols-1 md-grid-cols-5 gap-8">
      {%- for block in section.blocks -%}
        <div class="mockup-feature-card flex flex-col items-center text-center" {{ block.shopify_attributes }}>
          <div class="mockup-feature-card__icon mb-4 text-primary">
            <!-- Using a generic placeholder icon with a blue outline circle matching mockup -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="40" height="40" class="border-2 border-blue-100 rounded-full p-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-sm mb-2 text-text-primary">{{ block.settings.title | escape }}</h3>
          <p class="text-xs text-secondary m-0 leading-relaxed max-w-[200px] mx-auto">{{ block.settings.text | escape }}</p>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  .mockup-why-choose-us {
    background-color: var(--color-background); /* #F8FAFC */
  }

  .text-primary { color: var(--color-primary); }
  .text-text-primary { color: var(--color-text-primary); }
  .text-secondary { color: #6b7280; }
  .text-sm { font-size: 0.875rem; }
  .text-xs { font-size: 0.75rem; }
  .font-bold { font-weight: 700; }
  .leading-relaxed { line-height: 1.625; }
  .max-w-\[200px\] { max-width: 200px; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  
  .border-2 { border-width: 2px; }
  .border-blue-100 { border-color: rgba(0,85,255,0.1); }
  .rounded-full { border-radius: 9999px; }
  .p-2 { padding: 0.5rem; }

  @media screen and (min-width: 750px) {
    .md-grid-cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  }
</style>

{% schema %}
{
  "name": "Mockup Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Why Choose Us",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Premium Quality",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Authentic products from top brands",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mockup Why Choose Us"
    }
  ]
}
{% endschema %}
