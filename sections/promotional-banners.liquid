<div class="mockup-promotional-banners py-16 animate-fade-up">
  <div class="page-width">
    <div class="grid grid-cols-1 md-grid-cols-3 gap-6">
      
      {%- for block in section.blocks -%}
        <div class="mockup-promo-card relative overflow-hidden rounded-2xl p-6 flex flex-col justify-center min-h-[220px]" {{ block.shopify_attributes }}>
          
          <div class="relative z-10 w-2/3">
            <h3 class="font-bold text-lg text-white mb-1">{{ block.settings.title | escape }}</h3>
            <p class="text-xs text-gray-400 mb-4">{{ block.settings.text | escape }}</p>
            <a href="{{ block.settings.button_link | default: routes.all_products_collection_url }}" class="text-xs font-bold text-blue-400 hover:text-white flex items-center gap-1 transition-colors no-underline">
              {{ block.settings.button_label | default: 'Shop Now' | escape }} &rarr;
            </a>
          </div>

          <div class="absolute right-0 bottom-0 w-1/2 h-full flex items-center justify-end pr-4 z-0">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.title | escape }}" width="300" height="auto" class="object-contain max-h-[80%]" loading="lazy">
            {%- else -%}
              {% if forloop.index == 1 %}
                 <img src="{{ 'mockup-keyboard.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="object-contain max-h-[80%] max-w-full opacity-80" loading="lazy">
              {% elsif forloop.index == 2 %}
                 <img src="{{ 'mockup-watch.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="object-contain max-h-[80%] max-w-full opacity-80" loading="lazy">
              {% else %}
                 <img src="{{ 'mockup-headphones.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="object-contain max-h-[80%] max-w-full opacity-80" loading="lazy">
              {% endif %}
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

<style>
  .mockup-promotional-banners {
    background-color: var(--color-secondary); /* #0B1120 */
  }

  .mockup-promo-card {
    background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
    border: 1px solid rgba(255,255,255,0.05);
  }

  .min-h-\[220px\] { min-height: 220px; }
  .w-2\/3 { width: 66.666667%; }
  .w-1\/2 { width: 50%; }
  .text-white { color: #fff; }
  .text-gray-400 { color: #9ca3af; }
  .text-blue-400 { color: #60a5fa; }
  .hover\:text-white:hover { color: #fff; }
  .no-underline { text-decoration: none; }
  .text-lg { font-size: 1.125rem; }
  .text-xs { font-size: 0.75rem; }
  .font-bold { font-weight: 700; }
  .object-contain { object-fit: contain; }
  .max-h-\[80\%\] { max-height: 80%; }
  .pr-4 { padding-right: 1rem; }
  .transition-colors { transition: color 0.2s ease; }

  @media screen and (min-width: 750px) {
    .md-grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
</style>

{% schema %}
{
  "name": "Mockup Promo Banners",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Special Offer",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "text",
          "default": "Up to 30% off",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Shop Now",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mockup Promo Banners",
      "blocks": [
        { "type": "banner", "settings": { "title": "Gaming Gear", "text": "Up to 30% Off" } },
        { "type": "banner", "settings": { "title": "Smart Watches", "text": "From $199" } },
        { "type": "banner", "settings": { "title": "Headphones", "text": "Up to 25% Off" } }
      ]
    }
  ]
}
{% endschema %}
