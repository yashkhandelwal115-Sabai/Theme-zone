<div class="password-header text-center py-4 w-100">
  <div class="password-logo">
    <h1 class="h2 m-0">{{ shop.name }}</h1>
  </div>
  <a href="#login-modal" class="button button--secondary mt-4 js-modal-open">Enter using password</a>
  <div id="login-modal" class="modal">
    <div class="modal__inner p-8">
      <h2 class="h3" id="DialogHeading">Enter store using password:</h2>
      {% form 'storefront_password', class: 'password-form' %}
        {%- if form.errors -%}
          <div class="form-message form-message--error" role="status">
            {{ form.errors.messages['form'] }}
          </div>
        {%- endif -%}
        <div class="password-field mt-4 flex justify-center">
          <input type="password" name="password" id="Password" class="field__input" autocomplete="current-password" placeholder="Your password" aria-label="Password">
          <button name="commit" class="button button--primary ml-2">Enter</button>
        </div>
      {% endform %}
      <p class="mt-4 text-sm">Are you the store owner? <a href="/admin" class="underlined-link">Log in here</a></p>
    </div>
  </div>
</div>

<style>
  .password-header { border-bottom: 1px solid rgba(0,0,0,0.1); }
  .modal { display: none; }
  .modal:target { display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 100; justify-content: center; align-items: center; }
  .modal__inner { background: var(--color-scheme-2-bg); color: var(--color-scheme-2-fg); border-radius: 8px; max-width: 400px; width: 100%; }
  .flex { display: flex; }
  .justify-center { justify-content: center; }
  .ml-2 { margin-left: 0.5rem; }
  .p-8 { padding: 2rem; }
  .w-100 { width: 100%; }
</style>

{% schema %}
{
  "name": "Password header",
  "settings": []
}
{% endschema %}
