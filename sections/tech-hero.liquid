<div class="tech-hero color-scheme-{{ section.settings.color_scheme }}" style="{% if section.settings.image != blank %}background-image: url('{{ section.settings.image | image_url: width: 2000 }}');{% endif %}">
  <div class="tech-hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  <div class="page-width tech-hero__inner text-center">
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'badge' -%}
          <span class="tech-hero__badge">{{ block.settings.text }}</span>
        {%- when 'heading' -%}
          <h2 class="tech-hero__heading h1">{{ block.settings.heading | escape }}</h2>
        {%- when 'subheading' -%}
          <div class="tech-hero__subheading h3">{{ block.settings.subheading | escape }}</div>
        {%- when 'buttons' -%}
          <div class="tech-hero__buttons mt-4">
            {%- if block.settings.button_label_1 != blank -%}
              <a href="{{ block.settings.button_link_1 }}" class="button button--primary">{{ block.settings.button_label_1 | escape }}</a>
            {%- endif -%}
            {%- if block.settings.button_label_2 != blank -%}
              <a href="{{ block.settings.button_link_2 }}" class="button button--secondary ml-4">{{ block.settings.button_label_2 | escape }}</a>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}

  </div>
</div>

<style>
  .tech-hero { position: relative; min-height: 600px; display: flex; align-items: center; justify-content: center; background-size: cover; background-position: center; background-color: #111; }
  .tech-hero__overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 1; }
  .tech-hero__inner { position: relative; z-index: 2; padding: 4rem 0; color: #fff; }
  .tech-hero__badge { display: inline-block; padding: 0.5rem 1rem; background: var(--color-scheme-1-bg); color: var(--color-scheme-1-fg); font-weight: bold; border-radius: 4px; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 1px; }
  .tech-hero__heading { font-size: 4rem; margin-bottom: 1rem; text-shadow: 0 4px 12px rgba(0,0,0,0.5); }
  .tech-hero__subheading { font-size: 1.5rem; opacity: 0.9; max-width: 800px; margin: 0 auto; }
  .ml-4 { margin-left: 1rem; }
  @media screen and (max-width: 749px) {
    .tech-hero { min-height: 400px; }
    .tech-hero__heading { font-size: 2.5rem; }
    .tech-hero__buttons { display: flex; flex-direction: column; gap: 1rem; }
    .ml-4 { margin-left: 0; }
  }
</style>

{% schema %}
{
  "name": "Tech Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 40
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "1", "label": "Electric Blue" },
        { "value": "2", "label": "Arctic White" },
        { "value": "3", "label": "Carbon Black" },
        { "value": "4", "label": "Neon Green" }
      ],
      "default": "3",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "New Arrival",
          "label": "Text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "The Future is Here",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "default": "Experience the next generation of technology with our latest products.",
          "label": "Subheading"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Shop Now",
          "label": "Button 1 label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "Learn More",
          "label": "Button 2 label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tech Hero",
      "blocks": [
        { "type": "badge" },
        { "type": "heading" },
        { "type": "subheading" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
