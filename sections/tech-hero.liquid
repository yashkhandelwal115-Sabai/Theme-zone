<div class="tech-hero section-{{ section.id }}" {% if section.settings.image != blank %}style="background-image: url('{{ section.settings.image | image_url: width: 2800 }}');"{% endif %}>
  <div class="tech-hero__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  
  <div class="page-width tech-hero__container flex flex-col justify-between h-full relative z-10">
    <div class="tech-hero__content animate-fade-up text-{{ section.settings.text_alignment }} mt-auto mb-auto pt-12">
      
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'badge' -%}
            {%- if block.settings.text != blank -%}
              <div class="tech-hero__badge-wrapper mb-6" {{ block.shopify_attributes }}>
                <span class="tech-hero__badge">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
            
          {%- when 'heading' -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="tech-hero__heading h1 text-white m-0" {{ block.shopify_attributes }}>
                {{ block.settings.heading | replace: '*', '<span class="text-primary">' | replace: '^', '</span>' }}
              </h1>
            {%- endif -%}
            
          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              <p class="tech-hero__subheading text-lg text-white mt-6 max-w-2xl {% if section.settings.text_alignment == 'center' %}mx-auto{% endif %}" {{ block.shopify_attributes }}>
                {{ block.settings.subheading | escape }}
              </p>
            {%- endif -%}
            
          {%- when 'buttons' -%}
            <div class="tech-hero__buttons flex gap-4 mt-10 {% if section.settings.text_alignment == 'center' %}justify-center{% endif %} {% if section.settings.text_alignment == 'right' %}justify-end{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a href="{{ block.settings.button_link_1 | default: '#' }}" class="button button--primary">{{ block.settings.button_label_1 | escape }}</a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a href="{{ block.settings.button_link_2 | default: '#' }}" class="button button--secondary tech-hero__btn-secondary">{{ block.settings.button_label_2 | escape }}</a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
      
    </div>

    {%- assign trust_blocks = section.blocks | where: "type", "trust_feature" -%}
    {%- if trust_blocks.size > 0 -%}
      <div class="tech-hero__trust-bar w-full mt-auto mb-6 animate-fade-up" style="animation-delay: 0.2s;">
        <div class="tech-hero__trust-grid">
          {%- for block in trust_blocks -%}
            <div class="tech-hero__trust-item" {{ block.shopify_attributes }}>
              <div class="tech-hero__trust-icon text-primary flex-shrink-0">
                {%- if block.settings.icon_svg != blank -%}
                  {{ block.settings.icon_svg }}
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5l10 -10"/></svg>
                {%- endif -%}
              </div>
              <div class="tech-hero__trust-text">
                <h4 class="text-white text-sm font-bold m-0 leading-tight">{{ block.settings.title }}</h4>
                {%- if block.settings.subtitle != blank -%}
                  <p class="text-xs m-0 mt-1 leading-tight" style="color: rgba(255,255,255,0.7);">{{ block.settings.subtitle }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .section-{{ section.id }} {
    position: relative;
    height: {{ section.settings.hero_height }};
    min-height: 600px;
    background-size: cover;
    background-position: {{ section.settings.image_position }};
    background-color: #0A0A0A; /* Dark premium fallback */
    overflow: hidden;
  }
  
  .tech-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10, 10, 15, 0.95) 0%, rgba(20, 25, 45, 0.7) 50%, rgba(10, 10, 15, 0.4) 100%);
    z-index: 1;
  }

  .tech-hero__content {
    width: 100%;
    max-width: 800px;
  }
  
  .tech-hero__content.text-center { margin-left: auto; margin-right: auto; }
  .tech-hero__content.text-right { margin-left: auto; }
  .tech-hero__content.text-left { margin-right: auto; }

  .tech-hero__badge {
    display: inline-flex;
    padding: var(--spacing-1) var(--spacing-4);
    background-color: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 30px;
    color: #FFF;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .tech-hero__heading {
    color: #FFFFFF;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .tech-hero__subheading {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 400;
    line-height: 1.6;
  }

  .tech-hero__btn-secondary {
    color: #FFF;
    border-color: rgba(255, 255, 255, 0.25);
    background: transparent;
  }
  
  .tech-hero__btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: #FFF;
  }

  /* Trust Bar Styling */
  .tech-hero__trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-6);
    background-color: rgba(15, 20, 30, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: var(--spacing-6) var(--spacing-8);
  }

  .tech-hero__trust-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
  }

  .tech-hero__trust-icon svg {
    width: 28px;
    height: 28px;
  }

  .text-white { color: #FFFFFF !important; }
  .text-primary { color: var(--color-primary) !important; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .max-w-2xl { max-width: 42rem; }
  .justify-end { justify-content: flex-end; }
  .z-10 { z-index: 10; }

  @media screen and (max-width: 1024px) {
    .tech-hero__trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }} {
      height: {{ section.settings.hero_height_mobile }};
    }
    .tech-hero__buttons {
      flex-direction: column;
      width: 100%;
    }
    .tech-hero__buttons .button {
      width: 100%;
    }
    .tech-hero__trust-grid {
      grid-template-columns: 1fr;
      padding: var(--spacing-5);
      gap: var(--spacing-5);
    }
  }
</style>

{% schema %}
{
  "name": "Tech Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        { "value": "top center", "label": "Top center" },
        { "value": "center center", "label": "Center" },
        { "value": "bottom center", "label": "Bottom center" }
      ],
      "default": "center center",
      "label": "Image position"
    },
    {
      "type": "select",
      "id": "hero_height",
      "options": [
        { "value": "60vh", "label": "Small" },
        { "value": "80vh", "label": "Medium" },
        { "value": "100vh", "label": "Full screen" }
      ],
      "default": "100vh",
      "label": "Desktop height"
    },
    {
      "type": "select",
      "id": "hero_height_mobile",
      "options": [
        { "value": "70vh", "label": "Small" },
        { "value": "85vh", "label": "Medium" },
        { "value": "100vh", "label": "Full screen" }
      ],
      "default": "100vh",
      "label": "Mobile height"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Dark overlay opacity",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Text alignment"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "New Arrival",
          "label": "Text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "The Future of *Technology is Here*",
          "label": "Heading",
          "info": "Wrap text in * and ^ to highlight it in the primary color. E.g., The Future of *Technology is Here^"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "subheading",
          "default": "Explore the latest smartphones, laptops, and tech accessories crafted for performance and style.",
          "label": "Subheading"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Shop Now",
          "label": "Button 1 label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "Explore Deals",
          "label": "Button 2 label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link"
        }
      ]
    },
    {
      "type": "trust_feature",
      "name": "Trust Feature",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Custom SVG Icon",
          "info": "Paste raw SVG code here for the icon."
        },
        {
          "type": "text",
          "id": "title",
          "default": "Free Shipping",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "default": "On orders over $99",
          "label": "Subtitle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Tech Hero",
      "blocks": [
        { "type": "badge" },
        { "type": "heading" },
        { "type": "subheading" },
        { "type": "buttons" },
        { "type": "trust_feature", "settings": { "title": "Free Shipping", "subtitle": "On orders over $99", "icon_svg": "<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 9h18v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z'/><path d='M3 9l9 -7l9 7v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z'/></svg>" } },
        { "type": "trust_feature", "settings": { "title": "Secure Payment", "subtitle": "100% secure checkout", "icon_svg": "<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='11' width='18' height='11' rx='2' ry='2'/><path d='M7 11V7a5 5 0 0 1 10 0v4'/></svg>" } },
        { "type": "trust_feature", "settings": { "title": "Easy Returns", "subtitle": "30-day return policy", "icon_svg": "<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 12a9 9 0 1 0 9 -9m0 0v4m0 -4h-4'/></svg>" } },
        { "type": "trust_feature", "settings": { "title": "24/7 Support", "subtitle": "Dedicated support", "icon_svg": "<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><path d='M12 16v-4'/><path d='M12 8h.01'/></svg>" } }
      ]
    }
  ]
}
{% endschema %}
