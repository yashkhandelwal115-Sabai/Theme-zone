{{ 'page-store-locator.css' | asset_url | stylesheet_tag }}

<div class="tz-page-stores">
  <div class="tz-page-stores__container">
    
    <!-- Header -->
    <div class="tz-page-stores__header">
      <h1 class="tz-page-stores__title">{{ section.settings.heading }}</h1>
      <p class="tz-page-stores__subtitle">{{ section.settings.subheading }}</p>
    </div>

    <!-- Main Layout -->
    <div class="tz-page-stores__layout">
      
      <!-- Left Sidebar: Store List -->
      <div class="tz-page-stores__sidebar">
        <div class="tz-page-stores__sidebar-header">
          <h2 class="tz-page-stores__sidebar-title">Our Locations</h2>
          <p class="tz-page-stores__sidebar-count">{{ section.blocks.size }} stores found</p>
        </div>
        
        <div class="tz-page-stores__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'store' -%}
              <div class="tz-card-store" {{ block.shopify_attributes }}>
                <div class="tz-card-store__header">
                  <h3 class="tz-card-store__title">{{ block.settings.title }}</h3>
                  {%- if block.settings.is_flagship -%}
                    <span class="tz-card-store__badge">Flagship</span>
                  {%- endif -%}
                </div>
                
                <div class="tz-card-store__info-list">
                  <div class="tz-card-store__info-item">
                    <svg class="tz-card-store__info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span>{{ block.settings.address | newline_to_br }}</span>
                  </div>
                  
                  <div class="tz-card-store__info-item">
                    <svg class="tz-card-store__info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone }}</a>
                  </div>
                  
                  <div class="tz-card-store__info-item">
                    <svg class="tz-card-store__info-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>{{ block.settings.hours | newline_to_br }}</span>
                  </div>
                </div>

                <a href="{{ block.settings.directions_link | default: '#' }}" target="_blank" class="tz-btn--directions">
                  Get Directions
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="tz-page-stores__empty">No stores found.</div>
          {%- endfor -%}
        </div>
      </div>

      <!-- Right Side: Map -->
      <div class="tz-page-stores__map-wrapper">
        {%- if section.settings.map_iframe != blank -%}
          <div class="tz-page-stores__map-iframe">
            {{ section.settings.map_iframe }}
          </div>
        {%- else -%}
          <!-- Placeholder Map -->
          <div class="tz-page-stores__map-placeholder">
            <div>
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
              <h3>Map goes here</h3>
              <p>Please add a Google Maps iframe embed code in the Theme Customizer to display the interactive map.</p>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

<style>
  .tz-page-stores__map-iframe iframe {
    width: 100% !important;
    height: 100% !important;
    border: none !important;
  }
</style>

{% schema %}
{
  "name": "Store Locator",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find a Store"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Visit one of our retail locations to experience our premium electronics in person."
    },
    {
      "type": "textarea",
      "id": "map_iframe",
      "label": "Google Maps Iframe Embed Code",
      "info": "Paste the HTML iframe code from Google Maps here."
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store Location",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Store Name",
          "default": "New York Flagship"
        },
        {
          "type": "checkbox",
          "id": "is_flagship",
          "label": "Is Flagship Store?",
          "default": false
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "123 Broadway St.\nNew York, NY 10001"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "(212) 555-0123"
        },
        {
          "type": "textarea",
          "id": "hours",
          "label": "Opening Hours",
          "default": "Mon - Sat: 10:00 AM - 8:00 PM\nSunday: 11:00 AM - 6:00 PM"
        },
        {
          "type": "url",
          "id": "directions_link",
          "label": "Google Maps Directions Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "store",
        "settings": {
          "title": "New York HQ",
          "is_flagship": true,
          "address": "123 Broadway St.\nNew York, NY 10001",
          "phone": "(212) 555-0123",
          "hours": "Mon - Sat: 10:00 AM - 8:00 PM\nSunday: 11:00 AM - 6:00 PM"
        }
      },
      {
        "type": "store",
        "settings": {
          "title": "San Francisco",
          "is_flagship": false,
          "address": "456 Market St.\nSan Francisco, CA 94104",
          "phone": "(415) 555-0198",
          "hours": "Mon - Fri: 9:00 AM - 7:00 PM\nSat - Sun: 10:00 AM - 5:00 PM"
        }
      },
      {
        "type": "store",
        "settings": {
          "title": "Chicago",
          "is_flagship": false,
          "address": "789 Michigan Ave.\nChicago, IL 60611",
          "phone": "(312) 555-0147",
          "hours": "Mon - Sat: 10:00 AM - 8:00 PM\nSunday: Closed"
        }
      }
    ]
  }
}
{% endschema %}
