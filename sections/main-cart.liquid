<div class="mockup-cart-page py-12 animate-fade-up">
  <div class="page-width">
    
    <div class="flex justify-between items-center mb-8">
      <h1 class="h2 m-0 font-bold" style="font-size: 2rem;">{{ 'sections.cart.title' | t }}</h1>
      <a href="{{ routes.all_products_collection_url }}" class="text-blue-500 font-bold hover:underline">{{ 'general.continue_shopping' | t }} &rarr;</a>
    </div>

    {%- if cart == empty -%}
      <div class="cart__empty text-center py-16 bg-white rounded-[20px] shadow-soft">
        <div class="mx-auto w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mb-6">
          {% render 'icon', icon: 'cart' %}
        </div>
        <h2 class="h3 font-bold mb-4">{{ 'sections.cart.empty' | t }}</h2>
        <a href="{{ routes.all_products_collection_url }}" class="button button--primary mt-4 px-8">Start Shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" class="cart__contents" method="post" id="cart">
        <div class="cart-layout grid grid-cols-1 lg-grid-cols-[1fr_400px] gap-8 items-start">
          
          <!-- Left Column: Cart Items -->
          <div class="cart-items-wrapper flex flex-col gap-4">
            {%- for item in cart.items -%}
              <div class="cart-item bg-white p-6 rounded-[16px] shadow-soft flex gap-6 relative" id="CartItem-{{ item.index | plus: 1 }}">
                
                <!-- Remove Button (Top Right) -->
                <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                  <a href="{{ item.url_to_remove }}" class="absolute top-4 right-4 text-gray-400 hover:text-red-500 transition-colors" aria-label="Remove {{ item.product.title | escape }}">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  </a>
                </cart-remove-button>

                <!-- Product Image -->
                <div class="cart-item__media w-[120px] h-[120px] bg-gray-50 rounded-[12px] flex items-center justify-center overflow-hidden flex-shrink-0">
                  {% if item.image %}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.image.alt | escape }}" loading="lazy" class="w-full h-full object-contain mix-blend-multiply p-2">
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'w-full h-full opacity-50' }}
                  {% endif %}
                </div>

                <!-- Product Details -->
                <div class="cart-item__details flex-1 flex flex-col">
                  
                  <a href="{{ item.url }}" class="h4 font-bold text-gray-900 mb-1 hover:text-blue-500 transition-colors pr-8">{{ item.product.title | escape }}</a>
                  
                  <!-- Stock Status -->
                  <div class="stock-status flex items-center gap-1 text-xs text-green-600 font-bold mb-2">
                    <div class="w-2 h-2 rounded-full bg-green-500"></div> In Stock
                  </div>

                  <!-- Variants -->
                  {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                    <dl class="text-sm text-gray-500 mb-4 flex gap-4">
                      {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          <div class="flex gap-1">
                            <dt class="font-semibold">{{ option.name }}:</dt>
                            <dd>{{ option.value }}</dd>
                          </div>
                        {%- endfor -%}
                      {%- endif -%}
                    </dl>
                  {%- endif -%}

                  <!-- Price & Quantity -->
                  <div class="flex items-center justify-between mt-auto">
                    
                    <div class="cart-item__price font-bold text-lg">
                      {%- if item.original_line_price != item.final_line_price -%}
                        <s class="text-sm text-gray-400 mr-2">{{ item.original_line_price | money }}</s>
                        <span class="text-red-500">{{ item.final_line_price | money }}</span>
                      {%- else -%}
                        <span>{{ item.original_line_price | money }}</span>
                      {%- endif -%}
                    </div>

                    <div class="cart-item__quantity">
                      <div class="quantity js-quantity-selector flex items-center border border-gray-200 rounded-full bg-gray-50 overflow-hidden">
                        <button class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-200 transition-colors js-qty-minus" name="minus" type="button">-</button>
                        <input class="w-12 text-center bg-transparent border-none font-bold focus:outline-none" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.product.title | escape }}" id="Quantity-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                        <button class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-200 transition-colors js-qty-plus" name="plus" type="button">+</button>
                      </div>
                    </div>

                  </div>
                </div>

              </div>
            {%- endfor -%}
          </div>

          <!-- Right Column: Sticky Summary -->
          <div class="cart-summary-wrapper sticky top-24">
            <div class="cart-summary bg-white p-8 rounded-[20px] shadow-hover border border-gray-100">
              <h2 class="h3 font-bold mb-6">Order Summary</h2>
              
              <div class="summary-rows flex flex-col gap-4 text-sm mb-6">
                <div class="flex justify-between text-gray-600">
                  <span>Subtotal</span>
                  <span class="font-bold text-gray-900">{{ cart.original_total_price | money }}</span>
                </div>
                
                {%- if cart.cart_level_discount_applications.size > 0 -%}
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="flex justify-between text-red-500 font-bold">
                      <span>Discount ({{ discount.title }})</span>
                      <span>-{{ discount.total_allocated_amount | money }}</span>
                    </div>
                  {%- endfor -%}
                {%- endif -%}

                <div class="flex justify-between text-gray-600">
                  <span>Estimated Shipping</span>
                  <span class="font-bold text-gray-900">Calculated at checkout</span>
                </div>
                
                <div class="flex justify-between text-gray-600">
                  <span>Estimated Tax</span>
                  <span class="font-bold text-gray-900">Calculated at checkout</span>
                </div>
              </div>

              <div class="border-t border-gray-100 pt-6 mb-6">
                <div class="flex justify-between items-center">
                  <span class="text-lg font-bold">Total</span>
                  <span class="text-2xl font-bold text-blue-600">{{ cart.total_price | money_with_currency }}</span>
                </div>
              </div>

              <div class="cart__ctas flex flex-col gap-3">
                <button type="submit" id="checkout" class="button button--primary w-full py-4 text-lg shadow-hover" name="checkout"{% if cart == empty %} disabled{% endif %} form="cart">
                  Proceed to Checkout
                </button>

                {%- if additional_checkout_buttons -%}
                  <div class="cart__dynamic-checkout-buttons mt-2 w-full">
                    {{ content_for_additional_checkout_buttons }}
                  </div>
                {%- endif -%}
              </div>

              <div class="trust-badges mt-6 pt-6 border-t border-gray-100 grid grid-cols-2 gap-4">
                <div class="flex items-center gap-2 text-xs text-gray-500 font-medium">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  Secure Checkout
                </div>
                <div class="flex items-center gap-2 text-xs text-gray-500 font-medium">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8V7a4 4 0 00-8 0v4h8z"></path></svg>
                  256-bit Encryption
                </div>
              </div>

            </div>
          </div>

        </div>
      </form>
    {%- endif -%}
  </div>
</div>

<style>
  .lg-grid-cols-\[1fr_400px\] {
    grid-template-columns: 1fr;
  }
  @media (min-width: 1024px) {
    .lg-grid-cols-\[1fr_400px\] {
      grid-template-columns: 1fr 400px;
    }
  }
  .sticky { position: sticky; }
  .top-24 { top: 6rem; }
  .w-\[120px\] { width: 120px; }
  .h-\[120px\] { height: 120px; }
  .flex-shrink-0 { flex-shrink: 0; }
  .mix-blend-multiply { mix-blend-mode: multiply; }
  .pr-8 { padding-right: 2rem; }
  .text-xs { font-size: 0.75rem; }
  .text-sm { font-size: 0.875rem; }
  .text-lg { font-size: 1.125rem; }
  .text-2xl { font-size: 1.5rem; }
  .text-gray-400 { color: #9CA3AF; }
  .text-gray-500 { color: #6B7280; }
  .text-gray-600 { color: #4B5563; }
  .text-gray-900 { color: #111827; }
  .text-green-600 { color: #16A34A; }
  .text-red-500 { color: #EF4444; }
  .text-blue-500 { color: #3B82F6; }
  .text-blue-600 { color: #2563EB; }
  .bg-gray-50 { background-color: #F9FAFB; }
  .bg-gray-200 { background-color: #E5E7EB; }
  .bg-green-500 { background-color: #22C55E; }
  .bg-transparent { background-color: transparent; }
  .border-gray-100 { border-color: #F3F4F6; }
  .border-gray-200 { border-color: #E5E7EB; }
  .border { border-width: 1px; border-style: solid; }
  .border-t { border-top-width: 1px; border-style: solid; }
  .border-none { border-style: none; }
  .rounded-\[12px\] { border-radius: 12px; }
  .rounded-\[16px\] { border-radius: 16px; }
  .rounded-\[20px\] { border-radius: 20px; }
  .shadow-soft { box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05); }
  .shadow-hover { box-shadow: 0 10px 40px rgba(10, 132, 255, 0.1); }
  .transition-colors { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
  .hover\:text-red-500:hover { color: #EF4444; }
  .hover\:text-blue-500:hover { color: #3B82F6; }
  .hover\:bg-gray-200:hover { background-color: #E5E7EB; }
  .hover\:underline:hover { text-decoration: underline; }
  .focus\:outline-none:focus { outline: 2px solid transparent; outline-offset: 2px; }
  
  .cart__dynamic-checkout-buttons [data-shopify-buttoncontainer] {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  @media screen and (max-width: 749px) {
    .cart-item {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem;
    }
    .cart-item__media {
      width: 100%;
      height: 200px;
    }
    .cart-summary-wrapper {
      position: static;
    }
    .cart-summary {
      padding: 1.5rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.js-quantity-selector button').forEach(button => {
    button.addEventListener('click', function() {
      const input = this.parentElement.querySelector('input');
      let val = parseInt(input.value);
      if (this.name === 'plus') {
        input.value = val + 1;
      } else if (this.name === 'minus' && val > 0) {
        input.value = val - 1;
      }
      document.querySelector('#cart').submit();
    });
  });
</script>

{% schema %}
{
  "name": "Cart items",
  "settings": []
}
{% endschema %}
