{%- if section.settings.enable_sticky_header -%}
  <script src="{{ 'sticky-header.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<div class="mockup-header-wrapper {% if section.settings.enable_sticky_header %}is-sticky{% endif %}">
  
  <!-- Main Header & Navigation -->
  <header class="header-main pt-6 pb-0">
    <div class="page-width">
      
      <div class="flex justify-between items-center mb-6">
        <!-- Logo -->
        <h1 class="header__heading m-0">
          <a href="{{ routes.root_url }}" class="header__heading-link flex items-center text-white" style="text-decoration: none;">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: 250 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto" loading="lazy">
            {%- else -%}
              <span class="h2 m-0" style="color: white; font-weight: 700; font-size: 28px;">Theme<span class="color-primary">Zone</span></span>
            {%- endif -%}
          </a>
        </h1>

        <!-- Search Bar with Predictive Search -->
        <div class="header__search hidden-mobile flex-1 mx-8 max-w-[600px] relative">
          <form action="{{ routes.search_url }}" method="get" role="search" class="search-form flex relative" onsubmit="handleSearch(event)">
            <input class="search-form__input field__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search for products..." autocomplete="off">
            <button class="search-form__button button button--primary" type="submit" aria-label="Search">
              <span style="pointer-events: none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
              </span>
            </button>
          </form>
          
          <!-- Predictive Search Dropdown -->
          <div class="predictive-search-results absolute w-full bg-surface rounded-xl shadow-lg mt-2 hidden" style="z-index: 50; max-height: 400px; overflow-y: auto; border: 1px solid var(--color-border); background-color: #1F2937;">
            <div class="predictive-search-results__inner p-4"></div>
          </div>
        </div>

        <!-- Icons -->
        <div class="header__icons flex items-center gap-8 text-white">
          <a href="#compare" class="header__icon-wrapper link text-center" data-compare-drawer-trigger>
            <div class="icon-container mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
            <span class="icon-label block text-xs mt-1">Compare</span>
          </a>

          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="header__icon-wrapper link text-center hidden-mobile">
            <div class="icon-container mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="icon-label block text-xs mt-1">Account</span>
          </a>

          <a href="{{ routes.cart_url }}" class="header__icon-wrapper link text-center relative" id="cart-icon-bubble">
            <div class="icon-container mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            </div>
            <span class="icon-label block text-xs mt-1">Cart</span>
            {%- if cart != empty -%}
              <div class="cart-badge flex items-center justify-center">
                <span>{{ cart.item_count }}</span>
              </div>
            {%- endif -%}
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div class="header-nav flex items-center justify-between border-t border-gray-800">
        <div class="flex items-center gap-8 w-100">
          
          <div class="categories-dropdown-menu flex items-center gap-2 py-4 cursor-pointer text-white font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            Categories
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </div>

          <ul class="list-menu list-menu--inline flex-1" role="list">
            {%- for link in section.settings.menu.links -%}
              <li>
                <a href="{{ link.url }}" class="list-menu__item link text-white text-sm {% if link.current %}active{% endif %}"{% if link.current %} aria-current="page"{% endif %}>
                  <span>{{ link.title | escape }}</span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>

    </div>
  </header>
</div>

<script>
  // 1. Search Form Submission Handler
  function handleSearch(e) {
    e.preventDefault();
    const form = e.target;
    const q = form.q.value.trim();
    
    if (q) {
      window.location.href = '/search?q=' + encodeURIComponent(q);
    }
  }

  // 2. Predictive Search Logic
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.querySelector('.search-form__input');
    const searchResults = document.querySelector('.predictive-search-results');
    const resultsContainer = document.querySelector('.predictive-search-results__inner');
    let debounceTimer;

    if (!searchInput) return;

    searchInput.addEventListener('input', function(e) {
      clearTimeout(debounceTimer);
      const query = e.target.value.trim();

      if (query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }

      debounceTimer = setTimeout(() => {
        fetch(`/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=5&section_id=predictive-search`)
          .then(response => response.json())
          .then(data => {
            const products = data.resources.results.products;
            if (products && products.length > 0) {
              let html = '<ul style="list-style: none; padding: 0; margin: 0;">';
              products.forEach(product => {
                const imageHtml = product.image ? `<img src="${product.image}" alt="${product.title}" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px; margin-right: 12px;">` : `<div style="width: 40px; height: 40px; background: #374151; border-radius: 4px; margin-right: 12px;"></div>`;
                html += `
                  <li style="margin-bottom: 8px;">
                    <a href="${product.url}" style="display: flex; align-items: center; text-decoration: none; padding: 8px; border-radius: 6px; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
                      ${imageHtml}
                      <div style="display: flex; flex-direction: column;">
                        <span style="color: #fff; font-size: 14px; font-weight: 500;">${product.title}</span>
                        <span style="color: var(--color-primary); font-size: 13px;">${product.price}</span>
                      </div>
                    </a>
                  </li>
                `;
              });
              html += '</ul>';
              html += `<a href="/search?q=${encodeURIComponent(query)}" style="display: block; text-align: center; color: var(--color-primary); text-decoration: none; font-size: 14px; margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.1);">View all results</a>`;
              resultsContainer.innerHTML = html;
              searchResults.classList.remove('hidden');
            } else {
              resultsContainer.innerHTML = `<div style="color: #9ca3af; text-align: center; padding: 12px;">No results found for "${query}"</div>`;
              searchResults.classList.remove('hidden');
            }
          })
          .catch(err => {
            console.error('Predictive search error:', err);
          });
      }, 300);
    });

    // Close predictive search when clicking outside
    document.addEventListener('click', function(e) {
      if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });
  });
</script>

<style>
  .mockup-header-wrapper {
    background-color: var(--color-secondary);
    position: relative;
    z-index: 100;
  }
  
  .mockup-header-wrapper.is-sticky {
    position: sticky;
    top: 0;
  }

  .header-main {
    background-color: var(--color-secondary);
  }

  /* Search Bar */
  .search-form {
    display: flex;
    background: #111827;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .search-category-dropdown {
    background: #1F2937;
    color: #9ca3af;
    padding: 0 1rem;
    font-size: 0.875rem;
    border-right: 1px solid rgba(255,255,255,0.1);
    max-width: 140px;
    text-overflow: ellipsis;
  }

  .search-form__input {
    background: transparent;
    border: none;
    color: #fff;
    padding: 0.75rem 1rem;
    flex: 1;
  }

  .search-form__input:focus { outline: none; box-shadow: none; }
  .search-form__input::placeholder { color: #6b7280; }

  .search-form__button {
    border-radius: 0;
    padding: 0 1.5rem;
  }

  /* Icons */
  .header__icon-wrapper {
    color: #fff;
    text-decoration: none;
    transition: color 0.2s;
  }

  .header__icon-wrapper:hover {
    color: var(--color-primary);
  }

  .icon-container svg {
    width: 24px; height: 24px;
  }

  .cart-badge {
    position: absolute;
    top: -5px; right: 5px;
    background: var(--color-primary);
    color: #fff;
    font-size: 10px;
    font-weight: bold;
    width: 16px; height: 16px;
    border-radius: 50%;
  }

  /* Navigation */
  .border-gray-800 { border-color: #1f2937; }
  .border-t { border-top-width: 1px; border-top-style: solid; }

  .categories-dropdown-menu svg { width: 16px; height: 16px; }

  .list-menu--inline {
    display: flex; gap: 2rem; list-style: none; padding: 0; margin: 0 0 0 2rem;
  }

  .list-menu__item {
    text-decoration: none;
    font-weight: 500;
    padding: 1.25rem 0;
    display: inline-block;
    position: relative;
    color: #d1d5db;
  }

  .list-menu__item:hover, .list-menu__item.active {
    color: #fff;
  }

  .list-menu__item.active::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; width: 100%; height: 3px;
    background: var(--color-primary);
  }

  /* Utilities */
  .max-w-\[600px\] { max-width: 600px; }
  .pr-8 { padding-right: 2rem; }
  .pt-6 { padding-top: 1.5rem; }
  .pb-0 { padding-bottom: 0; }
  .text-white { color: #fff; }
  .text-xs { font-size: 0.75rem; }
  .text-sm { font-size: 0.875rem; }
  .block { display: block; }
  .cursor-pointer { cursor: pointer; }
  .hidden { display: none !important; }

  /* Mobile Responsiveness */
  @media screen and (max-width: 800px) {
    .header-main .flex.justify-between.mb-6 {
      flex-wrap: wrap;
    }
    .header__heading {
      width: auto;
    }
    .header__icons {
      gap: 1rem;
    }
    .header__search {
      order: 3;
      width: 100%;
      max-width: 100%;
      margin: 10px 0 0 0;
      display: block !important;
    }
    .search-category-wrapper {
      display: none;
    }
    .header-nav {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 5px;
    }
    .list-menu--inline {
      margin-left: 1rem;
      gap: 1rem;
    }
    .categories-dropdown-menu {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Custom logo width"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header",
      "default": true,
      "label": "Enable sticky header"
    }
  ]
}
{% endschema %}
