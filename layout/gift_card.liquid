<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.colors_background_1 }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>Gift card - {{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
    <style>
      body { text-align: center; font-family: inherit; background-color: var(--color-scheme-2-bg); color: var(--color-scheme-2-fg); }
    </style>
  </head>
  <body class="gift-card-template">
    <main tabindex="-1">
      {{ content_for_layout }}
    </main>
  </body>
</html>
