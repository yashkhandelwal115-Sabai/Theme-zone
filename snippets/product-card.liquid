{%- comment -%}
  Accepts:
  - product: {Object} Product Liquid object
  - show_vendor: {Boolean} Show the product vendor. Default: false
  - show_rating: {Boolean} Show the product rating. Default: false
{%- endcomment -%}

<div class="product-card card relative group" {{ block.shopify_attributes }}>
  
  <!-- Badges -->
  <div class="product-card__badges absolute top-4 left-4 z-10 flex flex-col gap-2">
    {%- if product.tags contains 'New' -%}
      <span class="badge badge--new bg-accent text-white px-2 py-1 rounded text-xs font-bold uppercase">New</span>
    {%- endif -%}
    {%- if product.compare_at_price > product.price -%}
      <span class="badge badge--sale bg-red-500 text-white px-2 py-1 rounded text-xs font-bold uppercase">Sale</span>
    {%- endif -%}
  </div>

  <!-- Action Buttons (Wishlist & Compare) -->
  <div class="product-card__actions absolute top-4 right-4 z-10 flex flex-col gap-2 opacity-0 transform translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0">
    <button class="btn-icon bg-white rounded-full p-2 shadow hover:text-primary transition-colors" data-wishlist-btn data-product-handle="{{ product.handle }}" aria-label="Add to Wishlist">
      {% render 'icon', icon: 'heart' %}
    </button>
    <button class="btn-icon bg-white rounded-full p-2 shadow hover:text-primary transition-colors mt-2" data-compare-btn data-product-handle="{{ product.handle }}" aria-label="Add to Compare">
      {% render 'icon', icon: 'compare' %}
    </button>
  </div>

  <!-- Image -->
  <a href="{{ product.url | within: collection }}" class="product-card__image-wrapper block relative overflow-hidden bg-background" style="aspect-ratio: 1/1;">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 533 }}"
        alt="{{ product.featured_image.alt | escape }}"
        loading="lazy"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
        class="product-card__image absolute inset-0 w-full h-full object-contain p-4 transition-transform duration-500 group-hover:scale-110"
      >
      {%- if product.images[1] != blank -%}
        <img
          src="{{ product.images[1] | image_url: width: 533 }}"
          alt="{{ product.images[1].alt | escape }}"
          loading="lazy"
          width="{{ product.images[1].width }}"
          height="{{ product.images[1].height }}"
          class="product-card__image-secondary absolute inset-0 w-full h-full object-contain p-4 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
        >
      {%- endif -%}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg absolute inset-0 w-full h-full p-4' }}
    {%- endif -%}
  </a>

  <!-- Content -->
  <div class="product-card__content p-4 flex flex-col flex-grow">
    
    {%- if show_vendor -%}
      <div class="product-card__vendor text-xs text-secondary mb-1">{{ product.vendor }}</div>
    {%- endif -%}
    
    <h3 class="product-card__title h6 mb-2 line-clamp-2">
      <a href="{{ product.url | within: collection }}" class="text-primary-text hover:text-primary">{{ product.title | escape }}</a>
    </h3>
    
    <!-- Rating -->
    <div class="product-card__rating flex items-center gap-1 mb-2">
      <div class="flex text-yellow-400">
        {% render 'icon', icon: 'star' %}
        {% render 'icon', icon: 'star' %}
        {% render 'icon', icon: 'star' %}
        {% render 'icon', icon: 'star' %}
        {% render 'icon', icon: 'star' %}
      </div>
      <span class="text-xs text-secondary">(4.8)</span>
    </div>

    <!-- Price -->
    <div class="product-card__price mt-auto mb-4">
      {%- if product.compare_at_price > product.price -%}
        <s class="price-item price-item--regular text-secondary text-sm mr-2">{{ product.compare_at_price | money }}</s>
        <span class="price-item price-item--sale text-red-500 font-bold">{{ product.price | money }}</span>
      {%- else -%}
        <span class="price-item price-item--regular font-bold">{{ product.price | money }}</span>
      {%- endif -%}

      {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
        <div class="unit-price text-xs text-secondary mt-1">
          {{ product.selected_or_first_available_variant.unit_price | money }} /
          {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value != 1 -%}
            {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
          {%- endif -%}
          {{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
        </div>
      {%- endif -%}
    </div>

    <!-- Quick Add -->
    <form method="post" action="/cart/add" class="mt-auto">
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button type="submit" class="button button--full-width button--secondary product-card__quick-add" {% unless product.available %}disabled{% endunless %}>
        {%- if product.available -%}
          Add to Cart
        {%- else -%}
          Out of Stock
        {%- endif -%}
      </button>
    </form>
    
  </div>
</div>

<style>
  .product-card {
    height: 100%;
  }

  .group:hover .product-card__image-secondary {
    opacity: 1;
  }

  .group:hover .product-card__image {
    opacity: 0;
  }

  .group:hover .product-card__actions {
    opacity: 1;
    transform: translateX(0);
  }

  .pt-\[100\%\] { padding-top: 100%; }
  .absolute { position: absolute; }
  .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
  .top-4 { top: 1rem; }
  .left-4 { left: 1rem; }
  .right-4 { right: 1rem; }
  .z-10 { z-index: 10; }
  .opacity-0 { opacity: 0; }
  .transform { transform: translateX(1rem); }
  .transition-all { transition-property: all; transition-duration: 300ms; }
  .transition-transform { transition-property: transform; transition-duration: 500ms; }
  .transition-opacity { transition-property: opacity; transition-duration: 500ms; }
  .object-contain { object-fit: contain; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .flex-grow { flex-grow: 1; }
  .mt-auto { margin-top: auto; }
  .bg-white { background-color: #fff; }
  .bg-background { background-color: var(--color-background); }
  .rounded-full { border-radius: 9999px; }
  .shadow { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
  .text-yellow-400 { color: #fbbf24; }
  .text-red-500 { color: #ef4444; }
  .font-bold { font-weight: 700; }
  
  .btn-icon { border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; }
  .btn-icon.is-active { color: var(--color-primary); }
</style>
