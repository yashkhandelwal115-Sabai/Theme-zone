{
  "name": "Collection",
  "wrapper": "main",
  "sections": {
    "banner": {
      "type": "main-collection-banner",
      "settings": {
        "show_collection_description": true,
        "show_collection_image": true,
        "color_scheme": "2"
      }
    },
    "product_grid": {
      "type": "main-collection-product-grid",
      "settings": {
        "columns_desktop": 4,
        "columns_mobile": "2",
        "enable_filtering": true,
        "enable_sorting": true,
        "show_vendor": true
      }
    }
  },
  "order": [
    "banner",
    "product_grid"
  ]
}
