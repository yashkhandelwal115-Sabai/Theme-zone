{% layout 'gift_card' %}

<div class="gift-card page-width py-8">
  <div class="gift-card__header text-center mb-8">
    <h1 class="h2">{{ shop.name }}</h1>
    <h2 class="h3 mt-4">Here's your gift card!</h2>
  </div>

  <div class="gift-card__image-wrapper text-center mb-8">
    <img src="{{ 'gift-card/card.svg' | shopify_asset_url }}" alt="Gift card illustration" loading="lazy" width="400" height="auto" class="rounded">
  </div>

  <div class="gift-card__info text-center mb-8">
    <div class="gift-card__price h1 mb-4">
      {{ gift_card.initial_value | money_without_trailing_zeros: gift_card.currency }}
    </div>

    {%- if gift_card.enabled == false or gift_card.expired -%}
      <p class="gift-card__expired color-red">This gift card is expired or disabled.</p>
    {%- endif -%}

    <div class="gift-card__code-wrapper p-4 border rounded inline-block">
      <input type="text" class="gift-card__code text-center h4" value="{{ gift_card.code | format_code }}" aria-label="Gift card code" readonly>
    </div>
    <p class="mt-4 text-sm">Use this code at checkout to redeem your gift card.</p>

    <div class="gift-card__qr-code mt-8 inline-block p-4 border rounded" data-identifier="{{ gift_card.qr_identifier }}"></div>

    {%- if gift_card.pass_url -%}
      <div class="gift-card__apple-wallet mt-8">
        <a href="{{ gift_card.pass_url }}">
          <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" width="120" height="40" alt="Add to Apple Wallet" loading="lazy">
        </a>
      </div>
    {%- endif -%}

    <div class="gift-card__buttons mt-8 flex justify-center align-center">
      <a href="{{ shop.url }}" class="button button--primary" target="_blank" rel="noopener" aria-describedby="a11y-new-window-message">
        Start shopping
      </a>
      <button class="button button--secondary ml-4" onclick="window.print();">Print</button>
    </div>
  </div>
</div>

<script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    new QRCode(document.querySelector('.gift-card__qr-code'), {
      text: document.querySelector('.gift-card__qr-code').dataset.identifier,
      width: 120,
      height: 120
    });
  });
</script>

<style>
  .gift-card { max-width: 600px; margin: 0 auto; }
  .inline-block { display: inline-block; }
  .border { border: 1px solid rgba(0,0,0,0.1); }
  .p-4 { padding: 1rem; }
  .rounded { border-radius: 8px; }
  .gift-card__code { border: none; background: transparent; width: 100%; letter-spacing: 0.1em; outline: none; }
  .color-red { color: #E32C2B; }
  .ml-4 { margin-left: 1rem; }
  .flex { display: flex; }
  .justify-center { justify-content: center; }
  .align-center { align-items: center; }
  @media print {
    .button { display: none; }
  }
</style>
