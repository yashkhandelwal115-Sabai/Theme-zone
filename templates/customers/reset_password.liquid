<div class="customer reset-password page-width py-8 flex justify-center">
  <div class="reset-form-wrapper w-100" style="max-width: 400px;">
    <h1 class="h2 text-center mb-4">Reset account password</h1>
    <p class="text-center mb-8">Enter a new password for {{ email }}</p>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="form-message form-message--error mb-4">
          <h2 class="h5 m-0">Please adjust the following:</h2>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="field mb-4">
        <label for="password" class="form__label">Password</label>
        <input type="password" name="customer[password]" id="password" class="field__input" autocomplete="new-password">
      </div>

      <div class="field mb-4">
        <label for="password_confirmation" class="form__label">Confirm password</label>
        <input type="password" name="customer[password_confirmation]" id="password_confirmation" class="field__input" autocomplete="new-password">
      </div>

      <button class="button button--primary w-100 mt-4">Reset password</button>
    {%- endform -%}
  </div>
</div>

<style>
  .w-100 { width: 100%; }
  .form-message { padding: 1rem; border-radius: 8px; }
  .form-message--error { background: #fee; color: #E32C2B; }
</style>
